<Window x:Class="TimeTracker.InputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeTracker"
        mc:Ignorable="d"
        Title="InputBox" Height="145" Width="300" ResizeMode="CanMinimize">
    <StackPanel Margin="10">
        <TextBlock FontSize="20" FontWeight="DemiBold" >Enter name: </TextBlock>
        <TextBox x:Name="Input" Margin="0,5"></TextBox>
        <Button Margin="0,5" Click="Button_Click">OK</Button>
    </StackPanel>
</Window>
