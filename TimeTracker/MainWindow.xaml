<Window x:Class="TimeTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeTracker"
        mc:Ignorable="d"
        Title="WorkTimer" Height="450" Width="900" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Background="LightGray" Height="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="29*"/>
                <ColumnDefinition Width="46*"/>
            </Grid.ColumnDefinitions>

            <Menu Background="LightGray" VerticalAlignment="Center" Height="18" >
                <MenuItem Header="Time Manager" Background="LightCyan" Margin="5,0">
                    <MenuItem Header="ClearDB" Click="ClearBT_Click"/>
                    <MenuItem Header="Clear customer time DB" Click="ClearCustomer_Click"/>
                </MenuItem>
                <MenuItem Header="Customer" Background="LightCyan" Margin="5,0">
                    <MenuItem Header="Add new" Click="AddCustomer_Click"/>
                    <MenuItem Header="Change" Click="ChangeCustomer_Click"/>
                    <MenuItem Header="Rename" Click="RenameCustomer_Click"/>
                    <MenuItem Header="Delete" Click="DeleteCustomer_Click"/>
                </MenuItem>
            </Menu>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Height="18"  Margin="10,0">
                <TextBlock Width="70">Time Sum:</TextBlock>
                <TextBox Width="150" IsReadOnly="True" Margin="0,0,20,0" x:Name="TimeSumBox" TextAlignment="Center" >0.00</TextBox>

                <TextBlock Width="110">Customer Name:</TextBlock>
                <TextBox Width="150" IsReadOnly="True" x:Name="CustomerNameBox" TextAlignment="Center" >DEFAULT</TextBox>
            </StackPanel>
        </Grid>



        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Margin="10" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Vertical">
                        <Label FontSize="25" x:Name="TimerLabel" >Time: 00:00:00</Label>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Grid.Row="1">
                        <Button Margin="5" x:Name="StartBT" Click="StartBT_Click">Start</Button>
                        <Button Margin="5" x:Name="PauseBT" IsEnabled="False" Click="PauseBT_Click">Pause</Button>
                        <Button Margin="5" x:Name="StopBT" IsEnabled="False" Click="StopBT_Click">Stop</Button>
                        <Button Margin="5" x:Name="DeleteBT" IsEnabled="False" Click="DeleteBT_Click">Delete</Button>
                    </StackPanel>

                </Grid>
            </GroupBox>

            <GroupBox Margin="10" Grid.Column="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,7,5,3">
                        <Label Margin="5,0" Width="100" FontSize="14" VerticalAlignment="Center" FontWeight="Bold">Export</Label>
                        <Label Margin="5,0" VerticalAlignment="Center">Start</Label>
                        <DatePicker x:Name="ExportDateStart" VerticalAlignment="Center"/>
                        <Label Margin="5,0" VerticalAlignment="Center">End</Label>
                        <DatePicker x:Name="ExportDateEnd" VerticalAlignment="Center"/>
                        <Button Margin="10,0"  Width="50" x:Name="ExportBT" Click="ExportBT_Click">Export</Button>
                    </StackPanel>

                    <Separator Grid.Row="1" Opacity="0.25"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,7,5,3">
                        <Label Margin="5,0" Width="100" FontSize="14" VerticalAlignment="Center" FontWeight="Bold">Add manualy</Label>
                        <Label Margin="5,0" VerticalAlignment="Center">Start</Label>
                        <DatePicker x:Name="ManualAddDate" VerticalAlignment="Center"/>

                        <Label Margin="5,0" VerticalAlignment="Center">Time</Label>
                        <TextBox x:Name="ManualAddTimeH" VerticalAlignment="Center" TextAlignment="Center" Width="40" Text="0" LostFocus="Hcheck"/>
                        <Label  VerticalAlignment="Center">:</Label>
                        <TextBox x:Name="ManualAddTimeM" VerticalAlignment="Center"  TextAlignment="Center" Width="40" Text="0" LostFocus="Mcheck"/>

                        <Label Margin="5,0" VerticalAlignment="Center">Work time</Label>
                        <TextBox x:Name="ManualAddTime" VerticalAlignment="Center" Width="40" Text="0.00"/>
                        <Button Margin="10,0"  Width="50" x:Name="AddManual" Click="AddManual_Click">Add</Button>
                    </StackPanel>

                    <Separator Grid.Row="3"/>

                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Vertical"  x:Name="DataStack">
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
