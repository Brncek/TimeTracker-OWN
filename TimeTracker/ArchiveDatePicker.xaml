<Window x:Class="TimeTracker.ArchiveDatePicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeTracker"
        mc:Ignorable="d"
        Title="ArchiveDatePicker" Height="260" Width="300">
    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal">
            <TextBlock FontSize="16" FontWeight="DemiBold" >Select dates</TextBlock>
            <TextBlock Margin="10,0" VerticalAlignment="Center" x:Name="ErrorText" Foreground="Red" >ERROR</TextBlock>
        </StackPanel>
        <TextBlock Margin="5,5,5,0">Start</TextBlock>
        <DatePicker Margin="5,5,5,0" x:Name="DatePiskerStart"/>
        <TextBlock Margin="5,5,5,0">End</TextBlock>
        <DatePicker Margin="5,5,5,0" x:Name="DatePickerEnd" />
        <TextBlock Margin="5,5,5,0">Note</TextBlock>
        <TextBox Margin="5,5,5,5" x:Name="DataPickerNote" />
        <Button Margin="10" Click="OK_click">OK</Button>
        
    </StackPanel>
</Window>
